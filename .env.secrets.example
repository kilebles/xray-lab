# Идентификатор клиента — прописывается в серверный конфиг,
# клиент предъявляет его при подключении
XRAY_UUID=

# Приватный ключ Reality — только на сервере, используется для расшифровки handshake
REALITY_PRIVATE_KEY=

# Публичный ключ Reality — у клиента, используется для шифрования handshake
REALITY_PUBLIC_KEY=

# Короткий токен — вставляется в TLS handshake, сервер по нему отличает своих от чужих
REALITY_SHORT_ID=
